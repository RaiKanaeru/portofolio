# ═══════════════════════════════════════════════════════════
# RAIHAN ARIANSYAH — PORTFOLIO CONFIGURATION
# Copy this file to .env.local and fill in the values
# ═══════════════════════════════════════════════════════════

# Public URL of the deployed site (used for sitemap, OG tags, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# Optional: Analytics (if you add Google Analytics later)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Contact form endpoint (if you add a form service later)
# NEXT_PUBLIC_FORM_ENDPOINT=https://formspree.io/f/xxxxx
